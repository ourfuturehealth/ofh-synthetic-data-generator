!data/README.md

# Generated output folders. Keep documentation/placeholders; ignore generated files.
outputs/synthetic/*
outputs/qa/*
!outputs/README.md
!outputs/synthetic/README.md
!outputs/synthetic/.gitkeep
!outputs/qa/README.md
!outputs/qa/.gitkeep
